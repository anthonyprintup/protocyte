@PACKAGE_INIT@

if(NOT DEFINED PROTOCYTE_FETCH_PROTOBUF)
    set(PROTOCYTE_FETCH_PROTOBUF OFF CACHE BOOL "Fetch protobuf when protobuf CMake targets are unavailable.")
endif()

if(NOT DEFINED PROTOCYTE_PROTOBUF_GIT_TAG)
    set(
        PROTOCYTE_PROTOBUF_GIT_TAG
        "@PROTOCYTE_PROTOBUF_GIT_TAG@"
        CACHE STRING
        "protobuf git tag used when PROTOCYTE_FETCH_PROTOBUF is enabled."
    )
endif()

set_and_check(PROTOCYTE_PYTHON_SOURCE_ROOT "${PACKAGE_PREFIX_DIR}/@PROTOCYTE_INSTALL_PYTHONDIR@")
set_and_check(PROTOCYTE_PACKAGE_ROOT "${PROTOCYTE_PYTHON_SOURCE_ROOT}/protocyte")
set_and_check(PROTOCYTE_PROTO_DIR "${PACKAGE_PREFIX_DIR}/@PROTOCYTE_INSTALL_PROTODIR@")
set_and_check(PROTOCYTE_OPTIONS_PROTO "${PROTOCYTE_PROTO_DIR}/protocyte/options.proto")
set(
    PROTOCYTE_GENERATOR_SOURCES
    "${PROTOCYTE_PACKAGE_ROOT}/__init__.py"
    "${PROTOCYTE_PACKAGE_ROOT}/cpp.py"
    "${PROTOCYTE_PACKAGE_ROOT}/errors.py"
    "${PROTOCYTE_PACKAGE_ROOT}/main.py"
    "${PROTOCYTE_PACKAGE_ROOT}/model.py"
    "${PROTOCYTE_PACKAGE_ROOT}/parameters.py"
    "${PROTOCYTE_PACKAGE_ROOT}/plugin.py"
    "${PROTOCYTE_PACKAGE_ROOT}/runtime.py"
)

include("${CMAKE_CURRENT_LIST_DIR}/ProtocyteFunctions.cmake")
